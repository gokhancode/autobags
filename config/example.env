# Bags.fm
BAGS_API_KEY=your_bags_api_key_here
BAGS_FEE_WALLET=your_fee_wallet_address

# Solana
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
OPERATOR_WALLET_PRIVATE_KEY=your_private_key_here

# Wallet encryption (AES-256-GCM — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
WALLET_MASTER_KEY=generate_a_random_64_char_hex_string

# App
PORT=3500
NODE_ENV=development

# Fee sharing (% taken per trade as operator fee)
FEE_PERCENT=1.5

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
