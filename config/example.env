# Bags.fm
BAGS_API_KEY=your_bags_api_key_here
BAGS_PARTNER_KEY=your_partner_wallet_pubkey

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet encryption (AES-256-GCM — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
WALLET_MASTER_KEY=generate_a_random_64_char_hex_string

# Auth
JWT_SECRET=generate_a_random_secret_here

# App
PORT=3500
NODE_ENV=production

# Fee sharing (% taken per trade via Bags partner key)
FEE_PERCENT=1.5

# AI Trade Explanations (Groq — free at console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
