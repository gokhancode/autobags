# Get these from https://my.telegram.org/apps
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash

# Your autobags VPS endpoint
AUTOBAGS_URL=https://autobags.io/api/social/ingest
AUTOBAGS_SECRET=change_this_to_a_random_secret

# Optional: only monitor these group IDs (comma-separated)
# Leave empty to monitor ALL groups
MONITOR_GROUPS=

# Optional: filter keywords (default: crypto-related)
# FILTER_KEYWORDS=pump,moon,buy,call,gem,degen,sol,solana
